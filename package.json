{
  "name": "redmine-cli-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace scripts for redmine-cli",
  "license": "MIT OR Apache-2.0",
  "workspaces": [
    "npm/*"
  ],
  "scripts": {
    "check:npm": "npm --workspaces --if-present run check",
    "format:check:npm": "npm --workspaces --if-present run format:check"
  },
  "engines": {
    "node": ">=18"
  }
}
